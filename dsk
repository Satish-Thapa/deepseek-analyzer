#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────
#  dsk — DeepSeek CLI  ·  A beautiful terminal dashboard
#  https://github.com/deepseek-cli
# ─────────────────────────────────────────────────────────────
set -euo pipefail
VERSION="1.0.0"

# ── Paths ────────────────────────────────────────────────────
DATA_DIR="${HOME}/.deepseek-cli"
LOG_FILE="${DATA_DIR}/usage.jsonl"
CHAT_LOG="${DATA_DIR}/chat_history.jsonl"
PRICING_FILE="${DATA_DIR}/pricing.json"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
mkdir -p "$DATA_DIR"
touch "$LOG_FILE" "$CHAT_LOG"

# Copy pricing.json to data dir if missing but exists next to script
if [[ ! -f "$PRICING_FILE" && -f "${SCRIPT_DIR}/pricing.json" ]]; then
  cp "${SCRIPT_DIR}/pricing.json" "$PRICING_FILE"
fi

# ── Colors & Styles ──────────────────────────────────────────
if [[ -t 1 ]]; then
  RST='\033[0m'
  BOLD='\033[1m'
  DIM='\033[2m'
  ITALIC='\033[3m'
  UL='\033[4m'
  # Foregrounds
  RED='\033[38;5;196m'
  GREEN='\033[38;5;82m'
  YELLOW='\033[38;5;220m'
  BLUE='\033[38;5;69m'
  CYAN='\033[38;5;80m'
  MAGENTA='\033[38;5;177m'
  WHITE='\033[38;5;255m'
  GRAY='\033[38;5;245m'
  ORANGE='\033[38;5;208m'
  PINK='\033[38;5;213m'
  # Backgrounds
  BG_BLUE='\033[48;5;17m'
  BG_GRAY='\033[48;5;236m'
else
  RST='' BOLD='' DIM='' ITALIC='' UL=''
  RED='' GREEN='' YELLOW='' BLUE='' CYAN='' MAGENTA='' WHITE='' GRAY='' ORANGE='' PINK=''
  BG_BLUE='' BG_GRAY=''
fi

# ── Helpers ──────────────────────────────────────────────────
die()  { echo -e "${RED}${BOLD}✖ Error:${RST} ${RED}$1${RST}" >&2; exit 1; }
warn() { echo -e "${YELLOW}${BOLD}⚠ Warning:${RST} ${YELLOW}$1${RST}" >&2; }
info() { echo -e "${CYAN}${BOLD}ℹ${RST} ${WHITE}$1${RST}"; }

check_deps() {
  local missing=()
  for cmd in curl jq awk; do
    command -v "$cmd" &>/dev/null || missing+=("$cmd")
  done
  if [[ ${#missing[@]} -gt 0 ]]; then
    die "Missing dependencies: ${missing[*]}\n  Install them and try again."
  fi
}

check_api_key() {
  if [[ -z "${DEEPSEEK_API_KEY:-}" ]]; then
    echo ""
    echo -e "  ${RED}${BOLD}API key not set!${RST}"
    echo ""
    echo -e "  ${WHITE}Set your key:${RST}"
    echo -e "  ${DIM}export DEEPSEEK_API_KEY=\"sk-xxxxxxxxxxxxxxxx\"${RST}"
    echo ""
    echo -e "  ${GRAY}Get your key at: ${UL}https://platform.deepseek.com/api_keys${RST}"
    echo ""
    exit 1
  fi
}

separator() {
  local char="${1:-─}" len="${2:-45}"
  printf "${DIM}"
  printf '%*s' "$len" '' | tr ' ' "$char"
  printf "${RST}\n"
}

# Pretty box header
box_header() {
  local title="$1" width="${2:-45}"
  local pad=$(( (width - ${#title} - 2) / 2 ))
  echo ""
  echo -e "${BOLD}${BLUE}╔$(printf '%*s' "$width" '' | tr ' ' '═')╗${RST}"
  echo -e "${BOLD}${BLUE}║${RST}$(printf '%*s' "$pad" '')${BOLD}${WHITE} $title ${RST}$(printf '%*s' $(( width - pad - ${#title} - 2 )) '')${BOLD}${BLUE}║${RST}"
  echo -e "${BOLD}${BLUE}╚$(printf '%*s' "$width" '' | tr ' ' '═')╝${RST}"
}

# Progress bar with color
bar() {
  local pct=$1 width=30
  local filled=$(( pct * width / 100 ))
  local empty=$(( width - filled ))

  # Color based on percentage
  local bar_color="$GREEN"
  if [[ $pct -lt 25 ]]; then
    bar_color="$RED"
  elif [[ $pct -lt 50 ]]; then
    bar_color="$YELLOW"
  elif [[ $pct -lt 75 ]]; then
    bar_color="$ORANGE"
  fi

  printf "  ${DIM}[${RST}"
  printf "${bar_color}${BOLD}"
  printf '%*s' "$filled" '' | tr ' ' '█'
  printf "${RST}${DIM}"
  printf '%*s' "$empty" '' | tr ' ' '░'
  printf "${RST}${DIM}]${RST} "
  printf "${BOLD}${bar_color}%s%%${RST}\n" "$pct"
}

# Log an action
log_action() {
  local action="$1"
  echo "{\"ts\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\"action\":\"$action\"}" >> "$LOG_FILE"
}

# Format large numbers with commas (portable)
fmt_num() {
  echo "$1" | sed ':a;s/\B[0-9]\{3\}\>/.&/;ta' | sed 's/^\.//' 
}

# ── API Calls ────────────────────────────────────────────────
api_balance() {
  local resp
  resp=$(curl -sf --max-time 10 https://api.deepseek.com/user/balance \
    -H "Authorization: Bearer $DEEPSEEK_API_KEY" 2>/dev/null) || \
    die "Failed to reach DeepSeek API. Check your network connection."
  echo "$resp"
}

api_models() {
  local resp
  resp=$(curl -sf --max-time 10 https://api.deepseek.com/models \
    -H "Authorization: Bearer $DEEPSEEK_API_KEY" 2>/dev/null) || \
    die "Failed to reach DeepSeek API. Check your network connection."
  echo "$resp"
}

api_chat() {
  local model="$1" message="$2"
  local resp
  resp=$(curl -sf --max-time 60 https://api.deepseek.com/chat/completions \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer $DEEPSEEK_API_KEY" \
    -d "$(jq -n --arg model "$model" --arg msg "$message" '{
      model: $model,
      messages: [{role: "user", content: $msg}],
      stream: false
    }')" 2>/dev/null) || \
    die "Chat request failed. Check your network and API key."
  echo "$resp"
}

# ── Commands ─────────────────────────────────────────────────

cmd_dashboard() {
  check_api_key
  log_action "dashboard"

  local bal_json model_json
  bal_json=$(api_balance)
  model_json=$(api_models)

  local is_avail total granted topped_up
  is_avail=$(echo "$bal_json" | jq -r '.is_available // "unknown"')
  total=$(echo "$bal_json" | jq -r '.balance_infos[0].total_balance // "0"')
  granted=$(echo "$bal_json" | jq -r '.balance_infos[0].granted_balance // "0"')
  topped_up=$(echo "$bal_json" | jq -r '.balance_infos[0].topped_up_balance // "0"')

  # Status color
  local status_color="$GREEN" status_icon="●" status_text="Active"
  if [[ "$is_avail" != "true" ]]; then
    status_color="$RED"; status_icon="●"; status_text="Inactive"
  fi

  box_header "DeepSeek Dashboard" 45

  echo ""
  echo -e "  ${GRAY}Account Status${RST}  ${status_color}${BOLD}${status_icon} ${status_text}${RST}"
  echo -e "  ${GRAY}Total Balance${RST}   ${GREEN}${BOLD}\$${total}${RST}"
  if [[ "$granted" != "0" && "$granted" != "0.00" ]]; then
    echo -e "  ${GRAY}Granted${RST}         ${CYAN}\$${granted}${RST}"
  fi
  echo -e "  ${GRAY}Topped Up${RST}       ${WHITE}\$${topped_up}${RST}"
  echo ""

  # Balance bar
  local pct
  pct=$(awk "BEGIN{v=int(($total/30)*100); if(v>100) v=100; print v}")
  bar "$pct"

  # Models section
  echo ""
  echo -e "  ${BOLD}${MAGENTA}⬡ Available Models${RST}"
  separator "─" 45
  local models
  models=$(echo "$model_json" | jq -r '.data[].id' 2>/dev/null)
  if [[ -n "$models" ]]; then
    while IFS= read -r m; do
      echo -e "  ${CYAN}▸${RST} ${WHITE}${m}${RST}"
    done <<< "$models"
  else
    echo -e "  ${DIM}No models available${RST}"
  fi

  # Pricing estimates
  if [[ -f "$PRICING_FILE" ]]; then
    echo ""
    echo -e "  ${BOLD}${ORANGE}◆ Token Capacity Estimates${RST}"
    separator "─" 45

    while IFS= read -r m; do
      local input_price output_price
      input_price=$(jq -r --arg m "$m" '.[$m].input // empty' "$PRICING_FILE" 2>/dev/null)
      output_price=$(jq -r --arg m "$m" '.[$m].output // empty' "$PRICING_FILE" 2>/dev/null)

      if [[ -n "$input_price" && -n "$output_price" ]]; then
        local input_tokens output_tokens
        input_tokens=$(awk "BEGIN{printf \"%.1f\", ($total / $input_price) * 1000000}")
        output_tokens=$(awk "BEGIN{printf \"%.1f\", ($total / $output_price) * 1000000}")

        # Format to M (millions)
        local input_m output_m
        input_m=$(awk "BEGIN{printf \"%.1f\", $input_tokens / 1000000}")
        output_m=$(awk "BEGIN{printf \"%.1f\", $output_tokens / 1000000}")

        echo ""
        echo -e "  ${CYAN}${BOLD}${m}${RST}"
        echo -e "    ${GREEN}↓${RST} Input   ${WHITE}${input_m}M tokens${RST}  ${DIM}(\$${input_price}/M)${RST}"
        echo -e "    ${YELLOW}↑${RST} Output  ${WHITE}${output_m}M tokens${RST}  ${DIM}(\$${output_price}/M)${RST}"
      fi
    done <<< "$models"
  fi

  # Usage stats
  echo ""
  separator "─" 45
  local req_count
  req_count=$(wc -l < "$LOG_FILE" 2>/dev/null || echo "0")
  echo -e "  ${DIM}📊 API Calls Logged: ${WHITE}${req_count}${RST}"
  echo -e "  ${DIM}📅 $(date '+%B %d, %Y  %H:%M')${RST}"
  echo ""
}

cmd_balance() {
  check_api_key
  log_action "balance"
  api_balance | jq .
}

cmd_models() {
  check_api_key
  log_action "models"
  api_models | jq .
}

cmd_cost() {
  check_api_key
  local tokens="${1:-1000000}" model="${2:-deepseek-v4-flash}"

  if [[ ! -f "$PRICING_FILE" ]]; then
    die "Pricing file not found at ${PRICING_FILE}. Run install.sh first."
  fi

  local input_price output_price
  input_price=$(jq -r --arg m "$model" '.[$m].input // empty' "$PRICING_FILE" 2>/dev/null)
  output_price=$(jq -r --arg m "$model" '.[$m].output // empty' "$PRICING_FILE" 2>/dev/null)

  if [[ -z "$input_price" ]]; then
    die "Model '${model}' not found in pricing data."
  fi

  local input_cost output_cost
  input_cost=$(awk "BEGIN{printf \"%.4f\", ($tokens / 1000000) * $input_price}")
  output_cost=$(awk "BEGIN{printf \"%.4f\", ($tokens / 1000000) * $output_price}")

  box_header "Cost Estimate" 45

  echo ""
  echo -e "  ${GRAY}Model${RST}    ${CYAN}${BOLD}${model}${RST}"
  echo -e "  ${GRAY}Tokens${RST}   ${WHITE}$(printf "%'d" "$tokens" 2>/dev/null || echo "$tokens")${RST}"
  echo ""
  separator "─" 45
  echo -e "  ${GREEN}↓${RST} Input Cost   ${BOLD}\$${input_cost}${RST}  ${DIM}(\$${input_price}/M tokens)${RST}"
  echo -e "  ${YELLOW}↑${RST} Output Cost  ${BOLD}\$${output_cost}${RST}  ${DIM}(\$${output_price}/M tokens)${RST}"
  echo ""
}

cmd_chat() {
  check_api_key
  local model="${1:-deepseek-v4-flash}"

  box_header "DeepSeek Chat" 45
  echo ""
  echo -e "  ${DIM}Model: ${CYAN}${model}${RST}"
  echo -e "  ${DIM}Type ${WHITE}exit${RST}${DIM} or ${WHITE}quit${RST}${DIM} to leave.${RST}"
  echo ""
  separator "─" 45

  while true; do
    echo ""
    printf "${GREEN}${BOLD}  you ▸ ${RST}"
    local user_input
    IFS= read -r user_input
    
    if [[ -z "$user_input" ]]; then continue; fi
    if [[ "$user_input" =~ ^(exit|quit|q)$ ]]; then
      echo ""
      echo -e "  ${DIM}Goodbye! 👋${RST}"
      echo ""
      break
    fi

    echo ""
    echo -e "  ${DIM}Thinking...${RST}"

    local resp content
    log_action "chat:${model}"
    resp=$(api_chat "$model" "$user_input")
    content=$(echo "$resp" | jq -r '.choices[0].message.content // "No response"')

    # Log chat
    echo "{\"ts\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\"model\":\"$model\",\"user\":$(echo "$user_input" | jq -Rs .),\"assistant\":$(echo "$content" | jq -Rs .)}" >> "$CHAT_LOG"

    # Clear "Thinking..." line
    printf "\033[1A\033[2K"

    echo -e "  ${BLUE}${BOLD}  ai ◂ ${RST}${WHITE}${content}${RST}"
  done
}

cmd_history() {
  local n="${1:-10}"

  box_header "Recent Activity" 45

  if [[ ! -s "$LOG_FILE" ]]; then
    echo ""
    echo -e "  ${DIM}No activity recorded yet.${RST}"
    echo ""
    return
  fi

  echo ""
  tail -n "$n" "$LOG_FILE" | while IFS= read -r line; do
    local ts action
    ts=$(echo "$line" | jq -r '.ts // "?"')
    action=$(echo "$line" | jq -r '.action // "?"')
    
    local icon="📋"
    case "$action" in
      dashboard) icon="📊" ;;
      balance)   icon="💰" ;;
      models)    icon="🤖" ;;
      chat:*)    icon="💬" ;;
    esac
    
    echo -e "  ${icon} ${DIM}${ts}${RST}  ${WHITE}${action}${RST}"
  done
  echo ""

  # Chat history
  if [[ -s "$CHAT_LOG" ]]; then
    echo -e "  ${BOLD}${MAGENTA}Recent Chats${RST}"
    separator "─" 45
    echo ""
    tail -n 3 "$CHAT_LOG" | while IFS= read -r line; do
      local ts model user_msg
      ts=$(echo "$line" | jq -r '.ts // "?"')
      model=$(echo "$line" | jq -r '.model // "?"')
      user_msg=$(echo "$line" | jq -r '.user // "?"' | head -c 60)
      echo -e "  ${DIM}${ts}${RST} ${CYAN}${model}${RST}"
      echo -e "    ${GREEN}▸${RST} ${WHITE}${user_msg}${RST}${DIM}...${RST}"
      echo ""
    done
  fi
}

cmd_help() {
  box_header "DeepSeek CLI  v${VERSION}" 45

  echo ""
  echo -e "  ${BOLD}${WHITE}USAGE${RST}"
  echo -e "    ${CYAN}dsk${RST} ${WHITE}<command>${RST} ${DIM}[options]${RST}"
  echo ""
  echo -e "  ${BOLD}${WHITE}COMMANDS${RST}"
  echo ""
  echo -e "    ${GREEN}dashboard${RST}           ${DIM}Show account overview (default)${RST}"
  echo -e "    ${GREEN}balance${RST}             ${DIM}Raw balance JSON from API${RST}"
  echo -e "    ${GREEN}models${RST}              ${DIM}Raw models JSON from API${RST}"
  echo -e "    ${GREEN}chat${RST} ${WHITE}[model]${RST}        ${DIM}Interactive chat session${RST}"
  echo -e "    ${GREEN}cost${RST} ${WHITE}<tokens> [model]${RST}  ${DIM}Estimate cost for token count${RST}"
  echo -e "    ${GREEN}history${RST} ${WHITE}[n]${RST}         ${DIM}Show last n actions (default: 10)${RST}"
  echo -e "    ${GREEN}help${RST}                ${DIM}Show this help message${RST}"
  echo ""
  echo -e "  ${BOLD}${WHITE}EXAMPLES${RST}"
  echo ""
  echo -e "    ${DIM}\$${RST} ${CYAN}dsk${RST}                         ${DIM}# Dashboard${RST}"
  echo -e "    ${DIM}\$${RST} ${CYAN}dsk chat${RST}                    ${DIM}# Chat with deepseek-v4-flash${RST}"
  echo -e "    ${DIM}\$${RST} ${CYAN}dsk chat deepseek-v4-pro${RST}    ${DIM}# Chat with specific model${RST}"
  echo -e "    ${DIM}\$${RST} ${CYAN}dsk cost 5000000${RST}            ${DIM}# Cost for 5M tokens${RST}"
  echo -e "    ${DIM}\$${RST} ${CYAN}dsk cost 1000000 deepseek-v4-pro${RST}"
  echo ""
  echo -e "  ${BOLD}${WHITE}SETUP${RST}"
  echo ""
  echo -e "    ${WHITE}export${RST} ${CYAN}DEEPSEEK_API_KEY${RST}=${DIM}\"sk-xxxxxxxx\"${RST}"
  echo ""
  echo -e "  ${DIM}Data stored in: ${UL}~/.deepseek-cli/${RST}"
  echo ""
}

# ── Main ─────────────────────────────────────────────────────
check_deps

case "${1:-dashboard}" in
  dashboard)          cmd_dashboard ;;
  balance|bal)        cmd_balance ;;
  models|m)           cmd_models ;;
  chat|c)             cmd_chat "${2:-deepseek-v4-flash}" ;;
  cost)               cmd_cost "${2:-1000000}" "${3:-deepseek-v4-flash}" ;;
  history|hist|h)     cmd_history "${2:-10}" ;;
  help|--help|-h)     cmd_help ;;
  version|--version|-v)
    echo -e "${BOLD}${CYAN}dsk${RST} ${WHITE}v${VERSION}${RST}"
    ;;
  *)
    echo -e "${RED}Unknown command:${RST} $1"
    echo ""
    cmd_help
    exit 1
    ;;
esac
